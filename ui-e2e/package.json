{
  "name": "ui-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone Playwright UI E2E suite using POM architecture",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed --workers=1",
    "test:qa": "TEST_ENV=qa playwright test --workers=1",
    "test:qa:headed": "TEST_ENV=qa playwright test --headed --workers=1",
    "test:demo": "TEST_ENV=demo playwright test --workers=1",
    "test:demo:headed": "TEST_ENV=demo playwright test --headed --workers=1",
    "test:flow1": "TEST_ENV=qa playwright test tests/flows/1-normalFullCaseFlow.spec.js --headed --workers=1",
    "test:flow2": "TEST_ENV=qa playwright test tests/flows/2-normalFullCaseFlowwith2acc.spec.js --headed --workers=1",
    "test:flow3": "TEST_ENV=qa playwright test tests/flows/3-litigentfilecase.spec.js --headed --workers=1",
    "test:flow1:demo": "TEST_ENV=demo playwright test tests/flows/1-normalFullCaseFlow.spec.js --headed --workers=1",
    "test:flow2:demo": "TEST_ENV=demo playwright test tests/flows/2-normalFullCaseFlowwith2acc.spec.js --headed --workers=1",
    "test:flow3:demo": "TEST_ENV=demo playwright test tests/flows/3-litigentfilecase.spec.js --headed --workers=1",
    "run:all-flows": "node tests/flows/run-all-flows.js",
    "run:all-flows:headed": "node tests/flows/run-all-flows.js --headed",
    "run:all-flows:qa": "TEST_ENV=qa node tests/flows/run-all-flows.js",
    "run:all-flows:qa:headed": "TEST_ENV=qa node tests/flows/run-all-flows.js --headed",
    "run:all-flows:demo": "TEST_ENV=demo node tests/flows/run-all-flows.js",
    "run:all-flows:demo:headed": "TEST_ENV=demo node tests/flows/run-all-flows.js --headed",
    "generate-csv:demo": "node helpers/generate-csv.js --env=demo",
    "generate-csv:qa": "node helpers/generate-csv.js --env=qa",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}